{
  "name": "funda-scraper",
  "version": "1.0.0",
  "description": "Scrape and download images from Funda.nl listings",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "cheerio": "^1.0.0-rc.12",
    "p-limit": "^3.1.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
